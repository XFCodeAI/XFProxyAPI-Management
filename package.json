{
  "name": "xfproxyapi-management",
  "private": true,
  "version": "0.1.18",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite",
    "test": "tsc --noEmit",
    "test:gpt-session": "node --experimental-strip-types tests/gptSessionImport.test.mjs",
    "test:auth-files-group-assignment": "node --experimental-strip-types tests/authFilesGroupAssignment.test.mjs",
    "test:credential-groups-catalog": "node --experimental-strip-types tests/credentialGroupsCatalogPolling.test.mjs",
    "test:oauth-credential-target": "node --experimental-strip-types tests/oauthCredentialTarget.test.mjs",
    "test:oauth-credential-publication": "node --experimental-strip-types tests/oauthCredentialPublication.test.mjs",
    "test:oauth-dialog-lifecycle": "node --experimental-strip-types tests/oauthDialogLifecycle.test.mjs",
    "test:oauth-publication-flow": "node --experimental-strip-types tests/oauthPublicationFlow.test.mjs",
    "test:oauth-status-polling": "node --experimental-strip-types tests/oauthStatusPolling.test.mjs",
    "test:provider-dialog-lifecycle": "node tests/providerDialogLifecycle.test.mjs",
    "test:proxy-selection": "node --experimental-strip-types tests/proxySelectionDefault.test.mjs",
    "test:proxy-pools": "node tests/proxyPools.test.mjs",
    "test:usage-analytics": "node --experimental-strip-types tests/usageAnalytics.test.mjs",
    "test:dashboard-analytics": "node --experimental-strip-types tests/dashboardAnalytics.test.mjs",
    "build": "tsc --noEmit && vite build",
    "package": "node scripts/package-panel.mjs",
    "verify": "pnpm build && pnpm package",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/merge": "^6.12.0",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@uiw/react-codemirror": "^4.25.3",
    "axios": "1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.34.3",
    "motion-dom": "^12.42.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^17.0.8",
    "react-router": "^7.18.0",
    "react-router-dom": "^7.10.1",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "sass": "^1.94.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.10",
    "yazl": "^3.3.1"
  }
}
